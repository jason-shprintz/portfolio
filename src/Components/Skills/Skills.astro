---
import SectionWrapper from "../../shared/Components/SectionWrapper/SectionWrapper.astro";
import { skills } from "../../data/skills";
---

<SectionWrapper id="skills" title="Skills">
  <div class="ticker" aria-label="Skills ticker" role="region" aria-live="off">
    <div class="ticker-track">
      <div class="ticker-group">
        {
          skills.map((s) => (
            <div class="ticker-item">
              <img src={s.src} alt={s.alt} loading="lazy" />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</SectionWrapper>

<style>
  .ticker {
    overflow: hidden;
    width: 100%;
    padding: 0.5rem 0;
  }

  .ticker-track {
    display: flex;
    gap: 15px;
    align-items: center;
    flex-wrap: wrap;
  }

  .ticker-item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
  }

  .ticker-item img {
    height: 25px;
    display: block;
  }

  .ticker-group {
    display: flex;
    gap: 15px;
    align-items: center;
    flex-wrap: wrap;
  }
</style>
